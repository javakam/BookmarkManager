{
  "name": "bookmark-manager-extension",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "wxt prepare",
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:unit": "vitest run --exclude \"tests/build/**\" --exclude \"tests/e2e/**\"",
    "test:watch": "vitest --exclude \"tests/build/**\" --exclude \"tests/e2e/**\"",
    "pree2e": "npm run build",
    "e2e": "playwright test",
    "bench:search": "tsx scripts/bench-search.ts"
  },
  "dependencies": {
    "fuse.js": "7.4.2",
    "lucide-react": "1.24.0",
    "pinyin-pro": "3.28.1",
    "punycode": "2.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/punycode": "2.1.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/module-react": "1.2.2",
    "jsdom": "29.1.1",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  }
}
